# Tracking API Environment Configuration
# Copy to /etc/tracking-api.env and adjust values

# InfluxDB v2 connection (same token as ais-collector, read-only is sufficient)
INFLUXDB_URL=http://127.0.0.1:8086
INFLUXDB_TOKEN=<your-influxdb-token>
INFLUXDB_ORG=OE5ITH
INFLUXDB_BUCKET=tracking

# API listener (keep on localhost, expose via nginx reverse proxy)
LISTEN_HOST=127.0.0.1
LISTEN_PORT=8787

# CORS: restrict to your map frontend in production
# CORS_ORIGIN=https://karte.oe5ith.at
CORS_ORIGIN=*

# Maximum allowed query window in hours (safety cap, default 24)
MAX_HOURS=24

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
