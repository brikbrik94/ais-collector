# AIS Collector Environment Configuration
# Copy this file to /etc/ais-collector.env and adjust values

# AIS-Catcher JSON endpoint
AIS_URL=http://100.64.0.3:8100/ships.json

# InfluxDB v2 connection
INFLUXDB_URL=http://127.0.0.1:8086
INFLUXDB_TOKEN=<your-influxdb-token>
INFLUXDB_ORG=OE5ITH
INFLUXDB_BUCKET=tracking

# Poll interval in seconds
POLL_INTERVAL=10

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
